// ============================================================
// DBShift Platform — Master Schema
// PostgreSQL | SaaS platform + battle-tested infra engine
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum AuthType {
  SSH_KEY
  PASSWORD
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum ServerStatus {
  PENDING       // just added, not yet verified
  VERIFYING     // SSH connection test in progress
  CONNECTED     // reachable and Docker confirmed
  UNREACHABLE   // last health check failed
  MAINTENANCE   // manually paused
  ERROR         // permanent failure
}

enum OsType {
  UBUNTU
  DEBIAN
  CENTOS
  ALPINE
  FEDORA
  ARCH
  OTHER
}

// All deployable containers — apps AND databases are services.
// Database-specific fields live in config JSONB + typed infra columns.
enum ServiceType {
  APP
  DATABASE        // postgres, mysql, redis, mongo, etc.
  STATIC
  DOCKER_COMPOSE
  WORKER
}

enum ServiceStatus {
  CREATING      // being provisioned for the first time (replaces old DatabaseStatus.CREATING)
  RUNNING
  STOPPED
  ERROR
  DEPLOYING
  BUILDING
  RESTARTING
}

// Database engine — stored in Service.config.dbType JSON field.
// Kept as a native enum so the app layer can validate and switch on it.
enum DatabaseEngine {
  POSTGRESQL
  MYSQL
  MARIADB
  MONGODB
  REDIS
  KEYDB
  DRAGONFLY
  CLICKHOUSE
}

enum EnvVarScope {
  BUILD    // injected at build time only
  RUNTIME  // injected at runtime only
  ALL      // injected at both stages
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  DEPLOYING
  SUCCESS
  FAILED
  CANCELLED
}

enum DeploymentTrigger {
  MANUAL
  GIT_PUSH
  WEBHOOK
  SCHEDULE
  API
}

enum BackupType {
  FULL
  INCREMENTAL
}

enum BackupRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ============================================================
// USER & TEAM
// ============================================================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships   TeamMember[]
  servers       Server[]
  projects      Project[]
  apiTokens     ApiToken[]
  s3Credentials S3Credential[]

  @@map("users")
}

model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       TeamMember[]
  servers       Server[]
  projects      Project[]
  apiTokens     ApiToken[]
  s3Credentials S3Credential[]

  @@map("teams")
}

// App layer must enforce: exactly one OWNER per team, OWNER cannot leave.
model TeamMember {
  id       String   @id @default(uuid())
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

// ============================================================
// SERVER
//
// usedPorts (JSONB) tracks every port allocated on this VM.
// Updated whenever a service is provisioned or destroyed.
// Shape: [{ port: number, serviceId: string|null, status: "in_use"|"reserved" }]
//
// Credentials are in a separate 1-to-1 table so list/dashboard
// queries on Server never touch SSH keys or passwords.
// ============================================================

model Server {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  teamId        String?      @map("team_id")
  name          String
  ip            String
  sshPort       Int          @default(22) @map("ssh_port")
  osType        OsType       @default(OTHER) @map("os_type")
  status        ServerStatus @default(PENDING)
  dockerVersion String?      @map("docker_version")
  lastCheckedAt DateTime?    @map("last_checked_at")  // updated by 60s BullMQ job
  errorMessage  String?      @map("error_message")
  // port registry — prevents double-allocation when multiple databases provision at once
  usedPorts     Json         @default("[]") @map("used_ports")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  credential ServerCredential?
  services   Service[]

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@map("servers")
}

// Loaded only when opening an SSH connection — never in list queries.
// sshPrivateKey and sshPassword MUST be encrypted at the app layer (AES-256-GCM).
model ServerCredential {
  id            String   @id @default(uuid())
  serverId      String   @unique @map("server_id")
  authType      AuthType @map("auth_type")
  sshUsername   String   @default("root") @map("ssh_username")
  sshPrivateKey String?  @map("ssh_private_key") // set when authType = SSH_KEY
  sshPassword   String?  @map("ssh_password")    // set when authType = PASSWORD
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@map("server_credentials")
}

// ============================================================
// PROJECT → ENVIRONMENT → SERVICE
//
// Project     = product / repo grouping (owned by user or team)
// Environment = named slot: prod, staging, dev, etc.
// Service     = anything deployable: app, worker, static, OR a
//               database container — all are Services.
// ============================================================

model Project {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  teamId      String?  @map("team_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  environments Environment[]

  @@index([userId])
  @@index([teamId])
  @@map("projects")
}

model Environment {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("environments")
}

// ============================================================
// SERVICE
//
// Unified model for every deployable resource.
//
// WHY typed infra columns instead of pure JSONB:
//   containerId / containerName / volumeName are read on EVERY
//   start / stop / restart / health-check call by the deployment
//   engine. Parsing JSONB on each call adds overhead and loses
//   Prisma type-safety. These stay as typed columns.
//
//   connectionString is shown on every dashboard load. Keep it
//   as a typed column (masked in API responses).
//
// type-specific `config` JSONB shapes:
//
//   DATABASE:
//   {
//     "dbEngine":       "POSTGRESQL",     ← DatabaseEngine enum value
//     "dockerImage":    "postgres:16",
//     "dbUser":         "myuser",
//     "dbPassword":     "<AES-256-GCM>",  ← encrypted at app layer
//     "dbName":         "mydb"
//   }
//
//   APP (git):
//   { "gitRepoUrl": "...", "branch": "main", "buildPack": "NIXPACKS" }
//
//   APP (image):
//   { "dockerImage": "nginx:alpine", "registryUrl": null }
//
//   DOCKER_COMPOSE:
//   { "composeFilePath": "./docker-compose.yml" }
// ============================================================

model Service {
  id            String        @id @default(uuid())
  environmentId String        @map("environment_id")
  serverId      String        @map("server_id")
  name          String
  type          ServiceType
  status        ServiceStatus @default(STOPPED)

  // ── Docker infra (typed — read by engine on every infra call) ──
  containerId   String?       @map("container_id")
  containerName String?       @map("container_name")
  volumeName    String?       @map("volume_name")     // named Docker volume; persists across container deletes

  // ── Networking ──
  domain        String?
  internalPort  Int?          @map("internal_port")   // port inside the container
  exposedPort   Int?          @map("exposed_port")    // host-VM port (via socat TCP proxy)
  isPublic      Boolean       @default(false) @map("is_public")

  // Connection string stored here so dashboard never has to parse config JSONB.
  // Always masked (:password → :****) in API responses.
  connectionString String?    @map("connection_string")

  // ── Type-specific config ──
  config        Json          @default("{}")

  // ── Denormalised deploy state — no join needed on dashboard ──
  lastCommitHash  String?     @map("last_commit_hash")
  lastDeployedAt  DateTime?   @map("last_deployed_at")

  // ── Health monitoring — updated by 60s BullMQ server-check job ──
  lastHealthCheckAt DateTime? @map("last_health_check_at")
  errorMessage      String?   @map("error_message")

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  environment    Environment     @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  server         Server          @relation(fields: [serverId], references: [id], onDelete: Restrict)
  envVars        ServiceEnvVar[]
  deployments    Deployment[]
  backupPolicies BackupPolicy[]  // populated only when type = DATABASE

  @@index([environmentId])
  @@index([serverId])
  @@index([status])
  @@index([type])
  @@map("services")
}

// Secret values must be encrypted at app layer (AES-256-GCM).
model ServiceEnvVar {
  id        String      @id @default(uuid())
  serviceId String      @map("service_id")
  key       String
  value     String      // encrypted when isSecret = true
  isSecret  Boolean     @default(false) @map("is_secret")
  scope     EnvVarScope @default(ALL)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, key])
  @@index([serviceId])
  @@map("service_env_vars")
}

// ============================================================
// DEPLOYMENTS
//
// Logs use one row per line (not a TEXT blob) so they can be
// streamed to the UI incrementally. isError separates stderr.
// ============================================================

model Deployment {
  id         String            @id @default(uuid())
  serviceId  String            @map("service_id")
  status     DeploymentStatus  @default(QUEUED)
  trigger    DeploymentTrigger @default(MANUAL)
  commitHash String?           @map("commit_hash")
  startedAt  DateTime?         @map("started_at")
  finishedAt DateTime?         @map("finished_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  service Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  logs    DeploymentLog[]

  @@index([serviceId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("deployments")
}

model DeploymentLog {
  id           String   @id @default(uuid())
  deploymentId String   @map("deployment_id")
  line         Int
  output       String
  isError      Boolean  @default(false) @map("is_error")
  createdAt    DateTime @default(now()) @map("created_at")

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId, line])
  @@map("deployment_logs")
}

// ============================================================
// S3 BACKUP SYSTEM
//
// S3Credential  — reusable bucket config (owned by user or team).
//                 accessKey + secretKey encrypted at app layer.
//                 Shared across any number of backup policies.
//
// BackupPolicy  — "back up THIS service on THIS schedule to
//                  THAT bucket." Holds schedule, retention, type.
//                  schedule is nullable → manual-only policy.
//                  s3PathPrefix overrides S3Credential.pathPrefix.
//
// BackupRun     — one row per execution. Immutable audit log.
//                 s3Key is the exact object path written.
//                 updatedAt needed for BullMQ failed handler.
// ============================================================

// Works with AWS S3, Cloudflare R2, MinIO, Backblaze B2,
// DigitalOcean Spaces — anything S3-compatible.
model S3Credential {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")  // null if team-owned
  teamId     String?  @map("team_id")  // null if user-owned
  name       String                    // friendly label e.g. "R2 — production"
  endpoint   String?                   // null = AWS S3; set for R2/MinIO/GCS/etc.
  bucket     String
  region     String   @default("us-east-1")
  pathPrefix String?  @map("path_prefix") // default folder prefix inside the bucket
  accessKey  String   @map("access_key")  // encrypted at app layer
  secretKey  String   @map("secret_key")  // encrypted at app layer
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  backupPolicies BackupPolicy[]

  @@index([userId])
  @@index([teamId])
  @@map("s3_credentials")
}

model BackupPolicy {
  id             String     @id @default(uuid())
  serviceId      String     @map("service_id")       // must be a Service with type = DATABASE
  s3CredentialId String     @map("s3_credential_id")
  isEnabled      Boolean    @default(true) @map("is_enabled")
  schedule       String?                              // cron expression; null = manual-only
  backupType     BackupType @default(FULL) @map("backup_type")
  retentionDays  Int        @default(30) @map("retention_days") // 0 = keep forever
  s3PathPrefix   String?    @map("s3_path_prefix")   // folder prefix — NEVER overwritten by runs
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  s3Credential S3Credential @relation(fields: [s3CredentialId], references: [id], onDelete: Restrict)
  runs         BackupRun[]

  @@index([serviceId])
  @@index([s3CredentialId])
  @@map("backup_policies")
}

// One row per backup execution. Never mutated after completion (except status + error).
model BackupRun {
  id             String          @id @default(uuid())
  backupPolicyId String          @map("backup_policy_id")
  status         BackupRunStatus @default(PENDING)
  backupType     BackupType      @map("backup_type")
  s3Key          String?         @map("s3_key")        // exact object key written; never null on SUCCESS
  sizeBytes      BigInt?         @map("size_bytes")
  errorMessage   String?         @map("error_message")
  startedAt      DateTime?       @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at") // required for BullMQ failed handler

  policy BackupPolicy @relation(fields: [backupPolicyId], references: [id], onDelete: Cascade)

  @@index([backupPolicyId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("backup_runs")
}

// ============================================================
// API TOKENS
//
// Scoped to a user OR a team — app layer enforces one is set.
// Raw token shown once at creation; only the hash is stored.
// ============================================================

model ApiToken {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  teamId    String?   @map("team_id")
  name      String
  tokenHash String    @unique @map("token_hash")
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([teamId])
  @@map("api_tokens")
}
